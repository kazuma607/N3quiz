        const NUM_MONDAI1 = 5;  
        const NUM_MONDAI2 = 3;  
        let currentDay = 0;
        let selectedQuestions = { mondai1: [], mondai2: [] };
        let userAnswersMondai2 = {};

        const quizContainer = document.getElementById('quiz-container');
        const daySelector = document.getElementById('day-selector');
        const welcomeScreen = document.getElementById('welcome-screen');

        function shuffleArray(array) {
            const newArray = [...array];
            for (let i = newArray.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [newArray[i], newArray[j]] = [newArray[j], newArray[i]];
            }
            return newArray;
        }

        function processFurigana(text) {
            if (!text) return '';
            return text.replace(/([\u4e00-\u9faf\u3005]+)\[(.+?)\]/g, '<ruby>$1<rt>$2</rt></ruby>');
        }

        function createDayButtons() {
            const dayKeys = Object.keys(window.grammarQuizData || {}).map(Number).sort((a, b) => a - b);
            
            dayKeys.forEach(day => {
                const button = document.createElement('button');
                const label = day === 7 ? "まとめテスト" : `Day ${day}`;
                button.innerText = label;
                button.classList.add(
                    'day-btn', 'px-4', 'py-2', 'font-semibold', 'bg-white', 'text-blue-600', 
                    'rounded-lg', 'shadow-sm', 'border', 'border-blue-100', 'hover:bg-blue-50', 
                    'transition', 'min-w-[80px]'
                );
                button.dataset.day = day;
                button.addEventListener('click', () => selectDay(day));
                daySelector.appendChild(button);
            });
        }

        function selectDay(day) {
            currentDay = day;
            
            document.querySelectorAll('.day-btn').forEach(btn => {
                const isActive = parseInt(btn.dataset.day) === day;
                btn.classList.toggle('active', isActive);
                if(isActive) btn.classList.remove('bg-white', 'text-blue-600');
                else btn.classList.add('bg-white', 'text-blue-600');
            });

            const dayData = window.grammarQuizData[day];
            
            quizContainer.innerHTML = `
                <div class="text-center fade-in py-8">
                    <span class="inline-block px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm font-semibold mb-4">Day ${day}</span>
                    <h2 class="text-2xl font-bold text-gray-800 mb-2">${dayData.theme}</h2>
                    <p class="text-gray-500 mb-8">全 ${Math.min(dayData.mondai1.length, NUM_MONDAI1) + Math.min(dayData.mondai2.length, NUM_MONDAI2)} 問</p>
                    <button id="start-btn" class="px-8 py-3 bg-blue-600 text-white font-bold rounded-lg shadow-md hover:bg-blue-700 hover:shadow-lg transition transform hover:-translate-y-1">
                        クイズを始める
                    </button>
                </div>
            `;
            document.getElementById('start-btn').addEventListener('click', startQuiz);
        }

        function startQuiz() {
            const dayData = window.grammarQuizData[currentDay];
            
            const m1Count = Math.min(dayData.mondai1.length, NUM_MONDAI1);
            const m2Count = Math.min(dayData.mondai2.length, NUM_MONDAI2);
            
            selectedQuestions.mondai1 = shuffleArray([...dayData.mondai1]).slice(0, m1Count);
            selectedQuestions.mondai2 = shuffleArray([...dayData.mondai2]).slice(0, m2Count);
            userAnswersMondai2 = {};

            let html = `<form id="quiz-form" class="fade-in">`;

            if (selectedQuestions.mondai1.length > 0) {
                html += `<h3 class="flex items-center text-lg font-bold text-gray-700 mb-4 mt-2">
                    <span class="bg-blue-600 text-white w-8 h-8 rounded-full flex items-center justify-center mr-2 text-sm">1</span>
                    文の（　　）に入る最もよいものを選んでください。
                </h3>`;
                
                selectedQuestions.mondai1.forEach((q, index) => {
                    const qText = processFurigana(q.q).replace(/（　　）/g, '<span class="border-b-2 border-blue-400 px-2 mx-1 font-bold text-blue-600">（　　）</span>');
                    html += `
                        <div class="mb-8 bg-gray-50 p-5 rounded-lg border border-gray-100">
                            <p class="font-medium text-lg mb-4 text-gray-800 leading-relaxed">${index + 1}. ${qText}</p>
                            <div id="q1-${index}-options" class="space-y-2">`;
                    q.o.forEach((option, i) => {
                        html += `
                            <label class="choice-label flex items-center group">
                                <input type="radio" name="q1-${index}" value="${i}" class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500 mr-3">
                                <span class="text-gray-700 group-hover:text-gray-900">${processFurigana(option)}</span>
                            </label>`;
                    });
                    html += `</div></div>`;
                });
            }

            if (selectedQuestions.mondai2.length > 0) {
                html += `<h3 class="flex items-center text-lg font-bold text-gray-700 mb-4 mt-8">
                    <span class="bg-blue-600 text-white w-8 h-8 rounded-full flex items-center justify-center mr-2 text-sm">2</span>
                    ★に入る最もよいものを選んでください。
                </h3>`;
                
                selectedQuestions.mondai2.forEach((q, index) => {
                    userAnswersMondai2[index] = [];
                    const shuffledOptions = shuffleArray([...q.o]);
                    
                    const qText = processFurigana(q.q)
                        .replace(/＿/g, '<span class="text-gray-300 mx-0.5">__</span>')
                        .replace(/★/g, '<span class="text-yellow-500 text-xl mx-1">★</span>');

                    html += `
                        <div class="mb-8 bg-gray-50 p-5 rounded-lg border border-gray-100">
                            <p class="font-medium text-lg mb-4 text-gray-800 leading-relaxed">${index + 1}. ${qText}</p>
                            
                            <div id="reorder-answer-box-${index}" class="reorder-answer-box bg-white mb-4 shadow-inner text-lg font-medium text-blue-800 min-h-[50px]">
                                <span class="text-gray-400 text-sm w-full text-center placeholder-text">選択肢をクリックして並べてください</span>
                            </div>
                            
                            <div id="reorder-options-${index}" class="flex flex-wrap gap-2 mb-2">`;
                    
                    shuffledOptions.forEach((option) => {
                        const escapedOption = option.replace(/'/g, "\\'");
                        html += `<button type="button" onclick="selectReorderOption(this, ${index}, '${escapedOption}')" class="reorder-option shadow-sm">${processFurigana(option)}</button>`;
                    });
                    
                    html += `</div>
                             <div class="flex justify-end">
                                <button type="button" onclick="clearReorderOption(${index})" class="text-sm text-red-500 hover:text-red-700 hover:underline flex items-center">
                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    やり直す
                                </button>
                             </div>
                        </div>`;
                });
            }

            html += `
                <div class="text-center mt-10 mb-6">
                    <button type="submit" class="w-full sm:w-auto px-12 py-4 bg-green-600 text-white font-bold text-lg rounded-xl shadow-lg hover:bg-green-700 hover:shadow-xl transition transform hover:-translate-y-1 ring-4 ring-green-100">
                        答え合わせをする
                    </button>
                </div>
            </form>`;
            
            quizContainer.innerHTML = html;
            document.getElementById('quiz-form').addEventListener('submit', checkAnswers);
        }

        window.selectReorderOption = (btn, qIndex, text) => {
            const answerBox = document.getElementById(`reorder-answer-box-${qIndex}`);
            const placeholder = answerBox.querySelector('.placeholder-text');
            
            if (userAnswersMondai2[qIndex].length >= 4) return;

            if (placeholder) placeholder.style.display = 'none';
            
            btn.style.display = 'none'; 
            
            userAnswersMondai2[qIndex].push(text);
            
            const span = document.createElement('span');
            span.className = "px-3 py-1 bg-blue-100 text-blue-800 rounded-md border border-blue-200 animate-[fadeIn_0.2s_ease-out]";
            span.innerHTML = processFurigana(text);
            answerBox.appendChild(span);
        };

        window.clearReorderOption = (qIndex) => {
            userAnswersMondai2[qIndex] = [];
            
            const answerBox = document.getElementById(`reorder-answer-box-${qIndex}`);
            answerBox.innerHTML = `<span class="text-gray-400 text-sm w-full text-center placeholder-text">選択肢をクリックして並べてください</span>`;
            answerBox.classList.remove('correct', 'incorrect');

            const optionsDiv = document.getElementById(`reorder-options-${qIndex}`);
            const buttons = optionsDiv.querySelectorAll('button');
            buttons.forEach(btn => {
                btn.style.display = 'inline-block';
                btn.disabled = false;
            });
        };

        function checkAnswers(e) {
            e.preventDefault();
            const form = e.target;
            let score1 = 0;
            let score2 = 0;
            const total1 = selectedQuestions.mondai1.length;
            const total2 = selectedQuestions.mondai2.length;

            selectedQuestions.mondai1.forEach((q, index) => {
                const optionsDiv = document.getElementById(`q1-${index}-options`);
                const inputs = form.querySelectorAll(`input[name="q1-${index}"]`);
                const labels = optionsDiv.querySelectorAll('label');
                let selectedVal = null;

                inputs.forEach(input => {
                    if (input.checked) selectedVal = parseInt(input.value);
                    input.disabled = true;
                });

                if (selectedVal === q.a) {
                    score1++;
                    labels[selectedVal].classList.add('correct');
                } else {
                    if (selectedVal !== null) labels[selectedVal].classList.add('incorrect');
                    labels[q.a].classList.add('correct');
                    
                    const feedback = document.createElement('div');
                    feedback.className = "mt-2 text-sm text-red-600 font-semibold";
                    feedback.innerText = "正解: " + q.o[q.a];
                    optionsDiv.parentElement.appendChild(feedback);
                }
            });

            selectedQuestions.mondai2.forEach((q, index) => {
                const answerBox = document.getElementById(`reorder-answer-box-${index}`);
                const userAnswer = userAnswersMondai2[index].join('');
                const correctAnswer = q.a.join('');
                
                const btns = document.getElementById(`reorder-options-${index}`).querySelectorAll('button');
                btns.forEach(b => b.disabled = true);

                if (userAnswer === correctAnswer) {
                    score2++;
                    answerBox.classList.add('correct');
                    answerBox.innerHTML += `<span class="ml-auto text-green-600 font-bold text-xl">✓</span>`;
                } else {
                    answerBox.classList.add('incorrect');
                    
                    const correctDiv = document.createElement('div');
                    correctDiv.className = "mt-3 p-3 bg-red-50 border border-red-200 rounded text-red-800 text-sm";
                    correctDiv.innerHTML = `<strong>正解:</strong> ${q.a.join(' ')}`;
                    answerBox.parentElement.appendChild(correctDiv);
                }
            });

            const totalScore = score1 + score2;
            const maxScore = total1 + total2;
            const percentage = maxScore > 0 ? Math.round((totalScore / maxScore) * 100) : 0;
            
            let message = "";
            if (percentage === 100) message = "素晴らしい！満点です！🎉";
