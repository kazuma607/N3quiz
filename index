                    <p class="text-blue-600 font-bold text-lg mb-6">${message}</p>
                    
                    <div class="flex justify-center items-center mb-8">
                        <div class="relative w-32 h-32 flex items-center justify-center rounded-full border-4 border-blue-500 bg-white shadow-md">
                            <div>
                                <span class="text-4xl font-bold text-gray-800">${totalScore}</span>
                                <span class="text-gray-500 text-xl">/${maxScore}</span>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4 max-w-sm mx-auto mb-8">
                        <div class="bg-white p-3 rounded-lg shadow-sm">
                            <div class="text-xs text-gray-500 uppercase tracking-wide">問題1</div>
                            <div class="text-xl font-bold text-gray-800">${score1}/${total1}</div>
                        </div>
                        <div class="bg-white p-3 rounded-lg shadow-sm">
                            <div class="text-xs text-gray-500 uppercase tracking-wide">問題2</div>
                            <div class="text-xl font-bold text-gray-800">${score2}/${total2}</div>
                        </div>
                    </div>

                    <button onclick="resetQuiz()" class="px-8 py-3 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition shadow-md">
                        トップに戻る
                    </button>
                </div>
            `;

            quizContainer.insertAdjacentHTML('beforeend', resultHTML);
            document.querySelector('.bg-gradient-to-br').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function resetQuiz() {
            currentDay = 0;
            selectedQuestions = { mondai1: [], mondai2: [] };
            userAnswersMondai2 = {};

            document.querySelectorAll('.day-btn').forEach(btn => {
                btn.classList.remove('active');
                btn.classList.add('bg-white', 'text-blue-600');
            });

            quizContainer.innerHTML = `
                <div id="welcome-screen" class="text-center py-10 fade-in">
                    <div class="mb-6 text-6xl">📖</div>
                    <h2 class="text-2xl font-semibold mb-4 text-gray-800">学習を始めましょう</h2>
                    <p class="text-gray-500 max-w-md mx-auto">上のボタンから学習したい日（Day）を選んでください。各日の文法ポイントに基づいた問題が出題されます。</p>
                </div>
            `;
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        document.addEventListener('DOMContentLoaded', createDayButtons);
    </script>
    <script>
        // ========================================
        // ふりがな（Kuroshiro）処理
        // ========================================
        let kuroshiroInstance = null;
        let isKuroshiroReady = false;

        async function initKuroshiro() {
            try {
                const KuroshiroClass = typeof Kuroshiro !== 'undefined' && Kuroshiro.default ? Kuroshiro.default : Kuroshiro;
                kuroshiroInstance = new KuroshiroClass();
                await kuroshiroInstance.init(new KuromojiAnalyzer({
                    dictPath: "https://cdn.jsdelivr.net/npm/kuromoji@0.1.2/dict"
                }));
                isKuroshiroReady = true;
                
                // Add global click listener for ruby tags
                document.addEventListener('click', function(e) {
                    let target = e.target;
                    while (target && target !== document) {
                        if (target.tagName && target.tagName.toLowerCase() === 'ruby') {
                            target.classList.toggle('show-furigana');
                            break;
                        }
                        target = target.parentNode;
                    }
                });
            } catch (e) {
                console.error("Kuroshiro initialization failed:", e);
            }
        }
        
        async function applyFurigana() {
            if (!isKuroshiroReady) return;
            
            // 変換対象のセレクタ (問題文、選択肢、並べ替え語句)
            const targets = document.querySelectorAll('.text-gray-800.leading-relaxed, .choice-label span, .reorder-option');
            
            for (let el of targets) {
                // 既に変換済みの場合はスキップ
                if (el.hasAttribute('data-furigana-applied')) continue;
                
                const originalHtml = el.innerHTML;
                // HTMLタグが含まれている場合は、テキストノードを再帰的に処理するのが理想だが、
                // KuroshiroのHTML変換機能を使用
                try {
                    const result = await kuroshiroInstance.convert(originalHtml, { mode: "furigana", to: "hiragana" });
                    el.innerHTML = result;
                    el.setAttribute('data-furigana-applied', 'true');
                } catch(e) {
                    console.error("Furigana conversion error:", e);
                }
            }
        }

        // ページ読み込み時にKuroshiroを初期化
        document.addEventListener('DOMContentLoaded', initKuroshiro);
        
        // original startQuiz関数をオーバーライドして、描画後にapplyFuriganaを呼ぶようにラップする
        const originalStartQuiz = window.startQuiz;
        if (typeof originalStartQuiz === 'function') {
            window.startQuiz = function() {
                originalStartQuiz();
                // 描画後にふりがなを適用する
                setTimeout(applyFurigana, 50);
            };
        } else {
            // W6のスクリプトでは startQuizはグローバルなのでこれで補足可能
            // イベントリスナーの元の処理を書き換える
            document.addEventListener('click', function(e) {
                if (e.target && e.target.id === 'start-btn') {
                    setTimeout(applyFurigana, 100);
                }
            });
        }
        </script>
</body>
</html>
